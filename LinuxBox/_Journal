{

# --- Backend Settings ---
# 'glx' é geralmente mais rápido para blur e efeitos. Use 'egl' se tiver problemas em GPUs NVIDIA modernas.
backend = "glx";
vsync = true;
use-damage = true;

# --- Opacity Settings ---
# Regras específicas substituem a opacidade global (active/inactive).
# Dica: Use 'xprop | grep WM_CLASS' para confirmar o nome exato da classe.
active-opacity = 0.87;
inactive-opacity = 0.65;
frame-opacity = 0.8;

# Garante que regras específicas não conflitem com a opacidade inativa global
inactive-opacity-override = false;

opacity-rule = [
  "100:class_g = 'Firefox'",
  "100:class_g = 'Brave-browser'", # Verifique se é 'Brave' ou 'Brave-browser' com xprop
  "100:class_g = 'vlc'",
  "75:class_g = 'Evince'"
];

# --- Fading Settings ---
fading = true;
fade-delta = 4;
fade-in-step = 0.03;
fade-out-step = 0.03;

# --- Blur Settings ---
# 'dual_kawase' é mais performático e moderno que 'kernel'. Requer backend 'glx' ou 'egl'.
blur-method = "dual_kawase";
blur-strength = 3;
blur-background = true;
blur-background-frame = false;
blur-background-fixed = false;

# Exclua docks ou desktops do blur se necessário
# blur-background-exclude = [ "window_type = 'dock'" ];

# --- Shadow Settings ---
# Desativado explicitamente para evitar processamento desnecessário
shadow = false;

# --- Wintypes (Opcional mas recomendado para consistência) ---
# Garante que menus e tooltips não herdem opacidades indesejadas
wintypes: {
  tooltip = { fade = true; shadow = false; opacity = 0.9; focus = true; full-shadow = false; };
  dock = { shadow = false; opacity = 1.0; };
  dnd = { shadow = false; };
  popup_menu = { opacity = 0.95; };
  dropdown_menu = { opacity = 0.95; };
};       
    
