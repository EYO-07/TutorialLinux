# BEGIN
# verbose commands for linux
# 1. verbose commands are easier to remember, less error prone
# 2. use tab for autocompletion in terminal

# -- alias | system 
alias errors='sudo dmesg -T --level=emerg,alert,crit,err,warn | tee ~/errors.txt'
alias processes='ps auxf | tee ~/processes.txt'
alias devices='lspci -k | tee ~/devices.txt'
alias storage_devices='(sudo blkid && sudo fdisk -l) | tee ~/storage_devices.txt'
alias mount_points='sudo blkid && sudo lsblk -l'
alias update_time='timedatectl status && timedatectl set-ntp true'

# -- alias | filesystem
alias mount_iso='mount -o loop'
alias create_file='touch'
alias create_folder='mkdir -pv'
function create_from_template { 
    if [[ "$#" -ne 2 ]]; then
        ls ~/Templates -l
        return 
    fi
    if [[ ! -f ~/Templates/"$1" ]]; then
        echo "Error: Template '$1' not found in ~/Templates/"
        ls ~/Templates -l
        return 
    fi
    cp --interactive --verbose ~/Templates/"$1" ./"$2"
}

